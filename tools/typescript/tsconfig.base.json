{
    "compilerOptions": {
        "target": "esnext",
        "lib": ["esnext"],
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "composite": true,
        "isolatedModules": true,
        "isolatedDeclarations": true,
        "incremental": true,
        "noEmitOnError": true
    }
}
