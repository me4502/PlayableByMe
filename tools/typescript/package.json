{
    "name": "@playablebyme/tsconfig",
    "private": true,
    "type": "module",
    "exports": {
        "./tsconfig.base.json": "./tsconfig.base.json",
        "./tsconfig.node-app.json": "./tsconfig.node-app.json",
        "./tsconfig.bundler.json": "./tsconfig.bundler.json"
    },
    "scripts": {
